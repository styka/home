# Neon PostgreSQL - get from https://console.neon.tech
# Use the "pooled" connection string for DATABASE_URL (via PgBouncer)
# Use the "direct" connection string for DIRECT_URL (for migrations)
DATABASE_URL="postgresql://user:password@ep-xxx-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxx-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# NextAuth — generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET="replace-with-random-secret"
AUTH_URL="http://localhost:3000"

# Google OAuth — Google Cloud Console → APIs & Services → Credentials → Create OAuth 2.0 Client
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
#   (prod: https://worldofmag.onrender.com/api/auth/callback/google)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Groq API key for LLM features (Notes AI tagging, Q&A, rewrite)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=""
