{
  "name": "worldofmag",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "typecheck": "tsc --noEmit",
    "test:unit": "node --import tsx --test \"src/**/*.test.ts\"",
    "check:actions": "node scripts/check-action-coverage.js",
    "check:migrations": "node scripts/check-migrations.js",
    "next:migration": "node scripts/check-migrations.js --next",
    "build": "node scripts/copy-docs.js && node scripts/copy-audyt.js && node scripts/check-action-coverage.js && node scripts/check-migrations.js && prisma generate && next build && node scripts/migrate.js",
    "start": "next start -H 0.0.0.0",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "seed:qa": "tsx prisma/seeds/qa-all.ts",
    "db:studio": "prisma studio",
    "test:e2e:local": "bash scripts/e2e.sh --headed",
    "test:e2e:local:down": "docker compose -f docker-compose.e2e.yml down -v",
    "test:e2e:docker": "bash scripts/e2e-docker.sh",
    "test:e2e": "DEMO=1 playwright test --headed",
    "test:e2e:desktop": "DEMO=1 playwright test --headed --project=desktop",
    "test:e2e:mobile": "DEMO=1 playwright test --headed --project=mobile",
    "test:e2e:ci": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:install": "playwright install chromium",
    "typecheck:e2e": "tsc -p e2e/tsconfig.json"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-collapsible": "^1.1.2",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@tanstack/react-virtual": "3.14.4",
    "@zxing/browser": "^0.2.0",
    "@zxing/library": "^0.22.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "date-fns": "^4.2.1",
    "emoji-picker-react": "^4.19.1",
    "lucide-react": "^0.468.0",
    "next": "14.2.29",
    "next-auth": "^5.0.0-beta.25",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.17.10",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.4.2",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
