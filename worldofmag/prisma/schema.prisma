datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── NextAuth required models ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  avatarUrl     String?
  role          String    @default("USER") // "USER" | "ADMIN"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts               Account[]
  sessions               Session[]
  ownedTeams             Team[]                @relation("TeamOwner")
  teamMemberships        TeamMember[]
  sentInvitations        TeamInvitation[]      @relation("InvitedBy")
  receivedInvitations    TeamInvitation[]      @relation("InvitedUser")
  ownedLists             ShoppingList[]
  products               Product[]
  units                  Unit[]
  categories             Category[]
  ownedTaskProjects      TaskProject[]         @relation("OwnedTaskProjects")
  taskProjectMemberships TaskProjectMember[]   @relation("TaskProjectMemberships")
  tasksCreated           Task[]                @relation("TasksCreatedBy")
  tasksAssigned          Task[]                @relation("TasksAssignedTo")
  taskComments           TaskComment[]         @relation("TaskComments")
  taskShares             TaskShare[]           @relation("TaskShares")
  activities             UserActivity[]
  stores                 Store[]
  categoryIconVariants   CategoryIconVariant[]
  userRoles              UserRole[]
  ownedNotes             Note[]                @relation("OwnedNotes")
  reports                Report[]              @relation("AuthoredReports")
  aiConversations        AiConversation[]      @relation("AiConversations")
  qaScenarios            QaTestScenario[]      @relation("QaAuthored")
  recipes                Recipe[]              @relation("OwnedRecipes")
  cookbooks              Cookbook[]            @relation("OwnedCookbooks")
  mealPlans              MealPlanEntry[]       @relation("OwnedMealPlans")
  pantryItems            PantryItem[]          @relation("OwnedPantryItems")
  storageItems           StorageItem[]         @relation("OwnedStorageItems")
  storageSuppliers       StorageSupplier[]     @relation("OwnedStorageSuppliers")
  storageDocuments       StorageDocument[]     @relation("OwnedStorageDocuments")
  storageOrders          StoragePurchaseOrder[] @relation("OwnedStorageOrders")
  storageSettings        StorageSettings?
  recipeRatings          RecipeRating[]
  vehicleProfile         VehicleProfile?
  ownedPets              Pet[]                 @relation("OwnedPets")
  petShares              PetShare[]            @relation("PetShares")
  ownedEnclosures        PetEnclosure[]        @relation("OwnedEnclosures")
  ownedBreedingPairs     PetBreedingPair[]     @relation("OwnedPairs")
  petSales               PetSale[]             @relation("OwnedPetSales")
  vehicles               Vehicle[]             @relation("OwnedVehicles")
  walletElements         WalletElement[]       @relation("OwnedWalletElements")
  languageDecks          LanguageDeck[]        @relation("OwnedLanguageDecks")
  healthEvents           HealthEvent[]         @relation("OwnedHealthEvents")
  medicationSchedules    MedicationSchedule[]  @relation("OwnedMedicationSchedules")
  habits                 Habit[]               @relation("OwnedHabits")
  serviceProvider        ServiceProvider?      @relation("UserServiceProvider")
  serviceCategories      ServiceCategory[]     @relation("OwnedServiceCategories")
  serviceRequestsAsClient ServiceRequest[]     @relation("ClientServiceRequests")
  serviceReviews         ServiceReview[]       @relation("AuthoredServiceReviews")
  menuPref               UserMenuPref?
  newsSources            NewsSource[]          @relation("OwnedNewsSources")
  newsTopics             NewsTopic[]           @relation("OwnedNewsTopics")
  newsPref               NewsPref?             @relation("NewsPref")
  weatherLocations       WeatherLocation[]     @relation("OwnedWeatherLocations")
  weatherWatchers        WeatherWatcher[]      @relation("OwnedWeatherWatchers")
  projectGroups          ProjectGroup[]        @relation("OwnedProjectGroups")
  skins                  Skin[]                @relation("SkinOwner")
  skinPref               UserSkinPref?
  warsztatSettings       WarsztatSettings?
  ownedWorkshops         Workshop[]            @relation("OwnedWorkshops")
  notifications          Notification[]        @relation("UserNotifications")
  serviceMessages        ServiceMessage[]      @relation("SentServiceMessages")
}

// Preferencje paska bocznego/menu per użytkownik: kolejność i wyłączone moduły.
model UserMenuPref {
  userId    String   @id
  order     String   @default("[]") // JSON: string[] id modułów w kolejności użytkownika
  disabled  String   @default("[]") // JSON: string[] id modułów wyłączonych przez użytkownika
  tabBar    String   @default("[]") // JSON: string[] id modułów w dolnym pasku (mobile), w kolejności użytkownika
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Skórka (motyw): częściowa mapa zmiennych CSS aplikowana inline na <html>.
// Skórki systemowe (isSystem=true, ownerId/ownerTeamId=null) zarządza admin.
// Skórki użytkownika/zespołu mają ownera; isPublic ⇒ widoczna i reużywalna przez wszystkich.
model Skin {
  id          String   @id @default(cuid())
  name        String
  description String?
  isSystem    Boolean  @default(false)
  colorScheme String   @default("dark") // "dark" | "light" — schemat natywnych kontrolek
  tokens      String   @default("{}")   // JSON: { "--bg-base":"#..", "--radius":"8px", ... }
  ownerId     String?
  ownerTeamId String?
  isPublic    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner     User? @relation("SkinOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerTeam Team? @relation("SkinTeam", fields: [ownerTeamId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([ownerTeamId])
}

// Wybrana przez użytkownika skórka (null ⇒ domyślna ciemna).
model UserSkinPref {
  userId    String   @id
  skinId    String?
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  role   String // "USER" | "ADMIN" | "BETA_TESTER"

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
}

model Permission {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]
}

model RolePermission {
  id           String @id @default(cuid())
  role         String
  permissionId String

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Teams ────────────────────────────────────────────────────────────────

model Team {
  id           String   @id @default(cuid())
  name         String
  description  String?
  avatarUrl    String?
  ownerId      String
  parentTeamId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner                User                  @relation("TeamOwner", fields: [ownerId], references: [id])
  parentTeam           Team?                 @relation("SubTeams", fields: [parentTeamId], references: [id])
  subTeams             Team[]                @relation("SubTeams")
  members              TeamMember[]
  invitations          TeamInvitation[]
  lists                ShoppingList[]        @relation("TeamLists")
  products             Product[]
  units                Unit[]
  categories           Category[]
  taskProjects         TaskProject[]         @relation("TeamTaskProjects")
  taskShares           TaskShare[]           @relation("TeamTaskShares")
  notes                Note[]                @relation("TeamNotes")
  categoryIconVariants CategoryIconVariant[] @relation("TeamIconVariants")
  reports              Report[]              @relation("TeamReports")
  recipes              Recipe[]              @relation("TeamRecipes")
  cookbooks            Cookbook[]            @relation("TeamCookbooks")
  mealPlans            MealPlanEntry[]       @relation("TeamMealPlans")
  pantryItems          PantryItem[]          @relation("TeamPantryItems")
  storageItems         StorageItem[]         @relation("TeamStorageItems")
  storageSuppliers     StorageSupplier[]     @relation("TeamStorageSuppliers")
  storageDocuments     StorageDocument[]     @relation("TeamStorageDocuments")
  storageOrders        StoragePurchaseOrder[] @relation("TeamStorageOrders")
  pets                 Pet[]                 @relation("TeamPets")
  petShares            PetShare[]            @relation("TeamPetShares")
  enclosures           PetEnclosure[]        @relation("TeamEnclosures")
  breedingPairs        PetBreedingPair[]     @relation("TeamPairs")
  petSales             PetSale[]             @relation("TeamPetSales")
  vehicles             Vehicle[]             @relation("TeamVehicles")
  walletElements       WalletElement[]       @relation("TeamWalletElements")
  languageDecks        LanguageDeck[]        @relation("TeamLanguageDecks")
  healthEvents         HealthEvent[]         @relation("TeamHealthEvents")
  medicationSchedules  MedicationSchedule[]  @relation("TeamMedicationSchedules")
  habits               Habit[]               @relation("TeamHabits")
  serviceCategories    ServiceCategory[]     @relation("TeamServiceCategories")
  skins                Skin[]                @relation("SkinTeam")
  workshops            Workshop[]            @relation("TeamWorkshops")
}

model TeamMember {
  teamId   String
  userId   String
  role     String   @default("MEMBER") // "MEMBER" | "ADMIN" | "OWNER"
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
}

model TeamInvitation {
  id            String   @id @default(cuid())
  teamId        String
  invitedById   String
  invitedUserId String
  status        String   @default("PENDING") // "PENDING" | "ACCEPTED" | "REJECTED"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  team        Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedBy   User @relation("InvitedBy", fields: [invitedById], references: [id])
  invitedUser User @relation("InvitedUser", fields: [invitedUserId], references: [id])

  @@unique([teamId, invitedUserId])
}

// ─── Shopping ─────────────────────────────────────────────────────────────

model ShoppingList {
  id          String    @id @default(cuid())
  name        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  ownerId     String?
  ownerTeamId String?
  archived    Boolean   @default(false)
  archivedAt  DateTime?

  owner     User?  @relation(fields: [ownerId], references: [id])
  ownerTeam Team?  @relation("TeamLists", fields: [ownerTeamId], references: [id])
  items     Item[]
}

model Item {
  id        String   @id @default(cuid())
  name      String
  quantity  Float?
  unit      String?
  category  String   @default("Other")
  status    String   @default("NEEDED")
  notes     String?
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  listId    String

  list         ShoppingList      @relation(fields: [listId], references: [id], onDelete: Cascade)
  recipeOrigin ItemRecipeOrigin?
}

model ItemHistory {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String
  unit      String?
  useCount  Int      @default(1)
  updatedAt DateTime @updatedAt
}

// ─── Product Catalog ──────────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  name        String
  category    String   @default("Other")
  defaultUnit String?
  useCount    Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  // userId=null AND teamId=null → global/seed product visible to everyone
  userId      String?
  teamId      String?

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team? @relation(fields: [teamId], references: [id], onDelete: Cascade)

  recipeIngredients RecipeIngredient[]
  pantryItems       PantryItem[]
}

// ─── System Config ────────────────────────────────────────────────────────

model Config {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// ─── Truck routing (Trasy TIR) ────────────────────────────────────────────
// Field names match the OpenRouteService `profile_params.restrictions` keys
// so they can be passed straight through to the routing request.

model VehicleProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  weight    Float    @default(40)   // tony (DMC)
  height    Float    @default(4.0)  // metry
  length    Float    @default(16.5) // metry
  width     Float    @default(2.55) // metry
  axleload  Float    @default(11.5) // tony / oś
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Custom Units ─────────────────────────────────────────────────────────

model Unit {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  // userId=null AND teamId=null → global base unit
  userId    String?
  teamId    String?

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team? @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([name, userId, teamId])
}

// ─── Custom Categories ────────────────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  name      String
  emoji     String   @default("📦")
  createdAt DateTime @default(now())
  // userId=null AND teamId=null → global base category
  userId    String?
  teamId    String?

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team? @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([name, userId, teamId])
}

// ─── Category Icon Variants ───────────────────────────────────────────────

model CategoryIconVariant {
  id           String   @id @default(cuid())
  categoryName String
  svgContent   String
  isActive     Boolean  @default(false)
  userId       String?
  teamId       String?
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team? @relation("TeamIconVariants", fields: [teamId], references: [id], onDelete: Cascade)

  @@index([userId, teamId, categoryName])
}

// ─── Notes ────────────────────────────────────────────────────────────────

model NoteGroup {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  notes       Note[]
}

model Tag {
  id        String      @id @default(cuid())
  name      String      @unique
  color     String?
  createdAt DateTime    @default(now())
  notes     NoteTag[]
  recipes   RecipeTag[]
}

model Note {
  id          String     @id @default(cuid())
  title       String
  content     String     @default("")
  isMarkdown  Boolean    @default(false)
  pinned      Boolean    @default(false)
  groupId     String?
  ownerId     String?
  ownerTeamId String?
  group       NoteGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  owner       User?      @relation("OwnedNotes", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerTeam   Team?      @relation("TeamNotes", fields: [ownerTeamId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tags        NoteTag[]
}

model NoteTag {
  noteId String
  tagId  String
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
}

// ─── Tasks ────────────────────────────────────────────────────────────────

model TaskProject {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#6b7280")
  emoji       String   @default("📋")
  isInbox     Boolean  @default(false)
  ownerId     String?
  ownerTeamId String?
  // JSON ProjectStatusConfig ({ enabled, chain }); null = domyślne statusy systemowe.
  statusConfig String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner     User?               @relation("OwnedTaskProjects", fields: [ownerId], references: [id])
  ownerTeam Team?               @relation("TeamTaskProjects", fields: [ownerTeamId], references: [id])
  tasks     Task[]
  members   TaskProjectMember[]
}

model TaskProjectMember {
  projectId String
  userId    String
  role      String   @default("MEMBER") // MEMBER | ADMIN | OWNER
  createdAt DateTime @default(now())

  project TaskProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User        @relation("TaskProjectMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
}

// Grupa projektów: stała, nazwana kombinacja projektów użytkownika (np. „Dom + Auto"),
// oglądana razem na /tasks/multi?group=<id>. Projekt może należeć do wielu grup (wiele-do-wielu),
// więc listę trzymamy jako JSON string[] (jak statusConfig / UserMenuPref) — bez tabeli łączącej.
// Nazwa tabeli w DB to historycznie „TaskView" (@@map) — koncepcja przemianowana na grupy.
model ProjectGroup {
  id         String   @id @default(cuid())
  name       String
  emoji      String   @default("🗂")
  color      String? // opcjonalny kolor (hex / token) na kropkę-znacznik przy projekcie
  projectIds String   @default("[]") // JSON: string[] id projektów w grupie
  ownerId    String
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  owner User @relation("OwnedProjectGroups", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@map("TaskView")
}

model TaskTagDef {
  id    String @id @default(cuid())
  name  String @unique
  color String @default("#6b7280")

  tasks TaskTaskTag[]
}

model Task {
  id            String    @id @default(cuid())
  title         String
  description   String?
  status        String    @default("TODO") // TODO | IN_PROGRESS | DONE | CANCELLED | DEFERRED
  priority      String    @default("NONE") // NONE | LOW | MEDIUM | HIGH | URGENT
  dueDate       DateTime?
  startDate     DateTime?
  completedAt   DateTime?
  estimatedMins Int?
  recurring     String? // JSON: RecurringRule
  category      String    @default("Other")
  order         Float     @default(0)
  projectId     String?
  parentTaskId  String?
  createdById   String?
  assigneeId    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  project   TaskProject?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  parent    Task?         @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks  Task[]        @relation("TaskSubtasks")
  createdBy User?         @relation("TasksCreatedBy", fields: [createdById], references: [id])
  assignee  User?         @relation("TasksAssignedTo", fields: [assigneeId], references: [id])
  tags      TaskTaskTag[]
  comments  TaskComment[]
  shares    TaskShare[]
}

model TaskTaskTag {
  taskId String
  tagId  String

  task Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  TaskTagDef @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User? @relation("TaskComments", fields: [userId], references: [id])
}

model TaskShare {
  id        String   @id @default(cuid())
  taskId    String
  userId    String?
  teamId    String?
  role      String   @default("VIEWER") // VIEWER | EDITOR
  createdAt DateTime @default(now())

  task Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User? @relation("TaskShares", fields: [userId], references: [id])
  team Team? @relation("TeamTaskShares", fields: [teamId], references: [id])
}

// ─── Activity Tracking ────────────────────────────────────────────────────

model UserActivity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  module    String // "shopping" | "tasks" | "notes"
  action    String // "add_item" | "create_task" | "create_note" | etc.
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// ─── Store Maps ───────────────────────────────────────────────────────────────

model Store {
  id        String      @id @default(cuid())
  name      String
  ownerId   String?
  nodes     StoreNode[]
  edges     StoreEdge[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  owner User? @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model StoreNode {
  id        String      @id @default(cuid())
  storeId   String
  label     String
  type      String      @default("CATEGORY")
  category  String?
  x         Float
  y         Float
  store     Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  edgesFrom StoreEdge[] @relation("EdgeFrom")
  edgesTo   StoreEdge[] @relation("EdgeTo")
}

model StoreEdge {
  id      String    @id @default(cuid())
  storeId String
  fromId  String
  toId    String
  weight  Float     @default(1)
  store   Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  from    StoreNode @relation("EdgeFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to      StoreNode @relation("EdgeTo", fields: [toId], references: [id], onDelete: Cascade)
}

// ─── Reports ──────────────────────────────────────────────────────────────

model Report {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String // markdown content
  category  String   @default("general")
  authorId  String?
  teamId    String?
  author    User?    @relation("AuthoredReports", fields: [authorId], references: [id], onDelete: SetNull)
  team      Team?    @relation("TeamReports", fields: [teamId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, createdAt])
  @@index([authorId])
  @@index([teamId])
}

// Asystent AI ("magiczna ikona") — trwała pamięć rozmów per-user.
model AiConversation {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("Nowa rozmowa")
  // Krótkie podsumowanie starszych tur — wysyłane do LLM zamiast pełnej historii
  // (higiena kontekstu w długich rozmowach).
  summary   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User        @relation("AiConversations", fields: [userId], references: [id], onDelete: Cascade)
  messages  AiMessage[]

  @@index([userId, updatedAt])
}

model AiMessage {
  id             String   @id @default(cuid())
  conversationId String
  role           String // "user" | "assistant" (TS union — bez enuma, zgodnie z regułą SQLite)
  content        String // markdown (asystent) / tekst (użytkownik)
  // Sidecar do odtworzenia kart w UI bez ponownego uruchamiania agenta.
  kind           String   @default("text") // "text" | "plan" | "report" | "navigate" | "clarify" | "results"
  data           Json? // actions[] | szkic raportu | cel nawigacji | log rozumowania
  createdAt      DateTime @default(now())
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// ─── Kitchen / Recipes ────────────────────────────────────────────────────

model Recipe {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  description   String?
  introMarkdown String?   @default("")
  notes         String?   @default("")
  servings      Int       @default(2)
  prepMinutes   Int?
  cookMinutes   Int?
  difficulty    String    @default("easy")
  cuisine       String?
  mealType      String?
  coverImageUrl String?
  ownerId       String?
  ownerTeamId   String?
  cookbookId    String?
  // K2: wartości odżywcze na 1 porcję (opcjonalne).
  kcal          Int?
  protein       Float?
  carbs         Float?
  fat           Float?
  cookCount     Int       @default(0)
  lastCookedAt  DateTime?
  rating        Float?
  sourceUrl     String?
  sourceType    String    @default("manual")
  isPublic      Boolean   @default(false)
  isArchived    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  owner          User?              @relation("OwnedRecipes", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerTeam      Team?              @relation("TeamRecipes", fields: [ownerTeamId], references: [id], onDelete: SetNull)
  cookbook       Cookbook?          @relation(fields: [cookbookId], references: [id], onDelete: SetNull)
  ingredients    RecipeIngredient[]
  steps          RecipeStep[]
  images         RecipeImage[]
  tags           RecipeTag[]
  plannedMeals   MealPlanEntry[]
  ratings        RecipeRating[]
  itemsGenerated ItemRecipeOrigin[] @relation("ItemsFromRecipe")

  @@index([ownerId])
  @@index([ownerTeamId])
  @@index([cookbookId])
  @@index([mealType, difficulty])
}

model RecipeIngredient {
  id         String  @id @default(cuid())
  recipeId   String
  productId  String?
  name       String
  quantity   Float?
  unit       String?
  groupName  String?
  order      Int     @default(0)
  note       String?
  isOptional Boolean @default(false)

  recipe  Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([recipeId])
  @@index([productId])
}

model RecipeStep {
  id          String  @id @default(cuid())
  recipeId    String
  order       Int
  text        String
  imageUrl    String?
  durationMin Int?
  temperature String?

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId, order])
}

model RecipeImage {
  id          String  @id @default(cuid())
  recipeId    String
  url         String
  caption     String?
  // Tekst odczytany ze zdjęcia przez LLM (OCR), jako Markdown. null = nie analizowano,
  // "" = przeanalizowano, brak tekstu na zdjęciu.
  ocrMarkdown String?
  order       Int     @default(0)
  isCover     Boolean @default(false)

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

model RecipeTag {
  recipeId String
  tagId    String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([recipeId, tagId])
}

model RecipeRating {
  id        String   @id @default(cuid())
  recipeId  String
  userId    String
  value     Int
  comment   String?
  createdAt DateTime @default(now())

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([recipeId, userId])
}

model Cookbook {
  id          String   @id @default(cuid())
  name        String
  description String?
  emoji       String   @default("📚")
  color       String?
  ownerId     String?
  ownerTeamId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner     User?    @relation("OwnedCookbooks", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerTeam Team?    @relation("TeamCookbooks", fields: [ownerTeamId], references: [id], onDelete: SetNull)
  recipes   Recipe[]

  @@index([ownerId])
  @@index([ownerTeamId])
}

model MealPlanEntry {
  id          String    @id @default(cuid())
  date        DateTime
  slot        String
  recipeId    String?
  customTitle String?
  servings    Int       @default(2)
  notes       String?
  ownerId     String?
  ownerTeamId String?
  status      String    @default("PLANNED")
  cookedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  recipe    Recipe? @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  owner     User?   @relation("OwnedMealPlans", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerTeam Team?   @relation("TeamMealPlans", fields: [ownerTeamId], references: [id], onDelete: SetNull)

  @@index([ownerId, date])
  @@index([ownerTeamId, date])
  @@index([date])
}

model PantryItem {
  id          String    @id @default(cuid())
  productId   String?
  name        String
  quantity    Float?
  unit        String?
  location    String?
  addedAt     DateTime  @default(now())
  expiresAt   DateTime?
  openedAt    DateTime?
  ownerId     String?
  ownerTeamId String?
  minQuantity Float?
  autoShop    Boolean   @default(false)

  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  owner     User?    @relation("OwnedPantryItems", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerTeam Team?    @relation("TeamPantryItems", fields: [ownerTeamId], references: [id], onDelete: Cascade)

  @@index([ownerId])
  @@index([ownerTeamId])
  @@index([productId])
  @@index([expiresAt])
}

// Moduł Magazynowanie — ogólny magazyn (dom/firma/gospodarstwo): garaż, strych,
// szafy, ale też magazyny firmowe/sklepowe/hurtownie. W odróżnieniu od kuchennej
// spiżarni nie jest food-centric (brak dat ważności/produktów), za to ma SKU,
// magazyn nadrzędny (warehouse) oraz dziennik ruchów (przyjęcie/wydanie/korekta).
model StorageItem {
  id           String    @id @default(cuid())
  name         String
  sku          String?
  barcode      String?
  category     String?
  warehouse    String?
  location     String?
  quantity     Float?
  unit         String?
  minQuantity  Float?
  unitPrice    Float?
  photoUrl     String?
  expiresAt    DateTime?
  warrantyUntil DateTime?
  supplierId   String?
  notes        String?
  ownerId      String?
  ownerTeamId  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  owner     User?             @relation("OwnedStorageItems", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerTeam Team?             @relation("TeamStorageItems", fields: [ownerTeamId], references: [id], onDelete: Cascade)
  supplier  StorageSupplier?  @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  movements StorageMovement[]
  batches   StorageBatch[]

  @@index([ownerId])
  @@index([ownerTeamId])
  @@index([warehouse])
  @@index([sku])
  @@index([barcode])
  @@index([supplierId])
}

model StorageMovement {
  id         String   @id @default(cuid())
  itemId     String
  delta      Float
  reason     String?
  note       String?
  batchId    String?
  documentId String?
  createdAt  DateTime @default(now())

  item StorageItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, createdAt])
}

// Preferencja użytkownika: tryb prosty (dom) vs profesjonalny (firma/magazyn).
model StorageSettings {
  userId    String   @id
  mode      String   @default("home") // "home" | "pro"
  currency  String   @default("PLN")
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Dostawca/kontrahent (tryb pro): faktury, zamówienia, preferowane źródło pozycji.
model StorageSupplier {
  id          String   @id @default(cuid())
  name        String
  contact     String?
  email       String?
  phone       String?
  notes       String?
  ownerId     String?
  ownerTeamId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner     User?                  @relation("OwnedStorageSuppliers", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerTeam Team?                  @relation("TeamStorageSuppliers", fields: [ownerTeamId], references: [id], onDelete: Cascade)
  items     StorageItem[]
  documents StorageDocument[]
  orders    StoragePurchaseOrder[]

  @@index([ownerId])
  @@index([ownerTeamId])
}

// Partia/seria (FEFO): podlot pozycji z własną ilością, numerem partii/serii i ważnością.
model StorageBatch {
  id         String    @id @default(cuid())
  itemId     String
  lotNo      String?
  serialNo   String?
  quantity   Float     @default(0)
  expiresAt  DateTime?
  receivedAt DateTime  @default(now())
  note       String?

  item StorageItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([expiresAt])
}

// Dokument magazynowy: PZ (przyjęcie), WZ (wydanie), faktura. Może powstać ze skanu.
model StorageDocument {
  id          String   @id @default(cuid())
  type        String // "PZ" | "WZ" | "faktura"
  number      String?
  supplierId  String?
  date        DateTime @default(now())
  totalCost   Float?
  imageUrl    String?
  notes       String?
  ownerId     String?
  ownerTeamId String?
  createdAt   DateTime @default(now())

  owner     User?                 @relation("OwnedStorageDocuments", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerTeam Team?                 @relation("TeamStorageDocuments", fields: [ownerTeamId], references: [id], onDelete: Cascade)
  supplier  StorageSupplier?      @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  lines     StorageDocumentLine[]

  @@index([ownerId])
  @@index([ownerTeamId])
  @@index([supplierId])
}

model StorageDocumentLine {
  id         String  @id @default(cuid())
  documentId String
  itemId     String?
  name       String
  quantity   Float   @default(0)
  unit       String?
  unitPrice  Float?
  lineTotal  Float?

  document StorageDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

// Zamówienie do dostawcy (tryb pro). Treść może zredagować LLM (draftText).
model StoragePurchaseOrder {
  id          String   @id @default(cuid())
  supplierId  String?
  status      String   @default("draft") // "draft" | "sent" | "received"
  date        DateTime @default(now())
  draftText   String?
  notes       String?
  ownerId     String?
  ownerTeamId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner     User?                      @relation("OwnedStorageOrders", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerTeam Team?                      @relation("TeamStorageOrders", fields: [ownerTeamId], references: [id], onDelete: Cascade)
  supplier  StorageSupplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  lines     StoragePurchaseOrderLine[]

  @@index([ownerId])
  @@index([ownerTeamId])
  @@index([supplierId])
}

model StoragePurchaseOrderLine {
  id       String  @id @default(cuid())
  orderId  String
  itemId   String?
  name     String
  quantity Float   @default(0)
  unit     String?

  order StoragePurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model ItemRecipeOrigin {
  itemId       String  @id
  recipeId     String
  servings     Int     @default(2)
  ingredientId String?

  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  recipe Recipe @relation("ItemsFromRecipe", fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

// ─── QA module: hierarchical test scenarios ────────────────────────────────

model QaEpic {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  module      String // "shopping" | "tasks" | "notes" | "kitchen" | "home" | "admin" | "settings" | "auth" | "teams" | "reports" | "qa"
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userStories QaUserStory[]

  @@index([module, order])
}

model QaUserStory {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  epicId      String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  epic      QaEpic           @relation(fields: [epicId], references: [id], onDelete: Cascade)
  scenarios QaTestScenario[]

  @@index([epicId, order])
}

model QaTestScenario {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  type      String   @default("positive") // "positive" | "negative" | "edge"
  priority  String   @default("P1") // "P0" | "P1" | "P2"
  content   String // markdown
  storyId   String
  authorId  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  story  QaUserStory @relation(fields: [storyId], references: [id], onDelete: Cascade)
  author User?       @relation("QaAuthored", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([storyId, order])
  @@index([priority])
  @@index([type])
}

// ─── Pets / Zwierzęta ───────────────────────────────────────────────────────
// Status/kind/category/role are String (not enum) — projektowa konwencja.
// featureFlags/recurring/details/payload trzymają JSON jako String.

model Pet {
  id           String    @id @default(cuid())
  name         String
  species      String    @default("other") // dog|cat|snake|lizard|turtle|fish|bird|rodent|rabbit|other
  breed        String? // rasa / morph / odmiana
  sex          String? // male|female|unknown
  birthDate    DateTime?
  birthApprox  Boolean   @default(false)
  acquiredAt   DateTime?
  acquiredFrom String?
  microchipId  String?
  identifier   String? // obrączka / tag
  color        String?
  photoUrl     String?
  status       String    @default("ACTIVE") // ACTIVE|DECEASED|REHOMED|SOLD|ARCHIVED
  deceasedAt   DateTime?
  notes        String?
  presetKey    String    @default("companion")
  featureFlags String? // JSON: { MEASUREMENTS: true, ... } — nadpisania per zwierzę
  enclosureId  String?
  sireId       String? // ojciec (rodowód)
  damId        String? // matka (rodowód)
  genetics     String? // JSON: [{ gene, mode, zygosity }] — genotyp/morphy
  ownerId      String?
  ownerTeamId  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  owner           User?             @relation("OwnedPets", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerTeam       Team?             @relation("TeamPets", fields: [ownerTeamId], references: [id], onDelete: Cascade)
  shares          PetShare[]
  enclosure       PetEnclosure?     @relation(fields: [enclosureId], references: [id], onDelete: SetNull)
  sire            Pet?              @relation("PetSire", fields: [sireId], references: [id], onDelete: SetNull)
  dam             Pet?              @relation("PetDam", fields: [damId], references: [id], onDelete: SetNull)
  offspringAsSire Pet[]             @relation("PetSire")
  offspringAsDam  Pet[]             @relation("PetDam")
  measurements    PetMeasurement[]
  healthRecords   PetHealthRecord[]
  vetVisits       PetVetVisit[]
  treatments      PetTreatment[]
  careTasks       PetCareTask[]
  careLogs        PetCareLog[]
  pairsAsMale     PetBreedingPair[] @relation("PairMale")
  pairsAsFemale   PetBreedingPair[] @relation("PairFemale")
  sales           PetSale[]

  @@index([ownerId])
  @@index([ownerTeamId])
  @@index([enclosureId])
  @@index([sireId])
  @@index([damId])
}

model PetShare {
  id        String   @id @default(cuid())
  petId     String
  userId    String?
  teamId    String?
  role      String   @default("VIEWER") // VIEWER|EDITOR
  createdAt DateTime @default(now())

  pet  Pet   @relation(fields: [petId], references: [id], onDelete: Cascade)
  user User? @relation("PetShares", fields: [userId], references: [id], onDelete: Cascade)
  team Team? @relation("TeamPetShares", fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([petId, userId])
  @@unique([petId, teamId])
  @@index([petId])
}

model PetMeasurement {
  id          String   @id @default(cuid())
  petId       String
  date        DateTime @default(now())
  weightGrams Float?
  lengthCm    Float?
  bodyScore   Int? // 1-9 BCS
  note        String?
  createdAt   DateTime @default(now())

  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId, date])
}

model PetHealthRecord {
  id          String   @id @default(cuid())
  petId       String
  type        String   @default("NOTE") // CONDITION|ALLERGY|SYMPTOM|INJURY|NOTE|MILESTONE
  title       String
  description String?
  date        DateTime @default(now())
  resolved    Boolean  @default(false)
  createdAt   DateTime @default(now())

  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId, date])
}

model PetVetVisit {
  id            String    @id @default(cuid())
  petId         String
  date          DateTime
  vetName       String?
  clinic        String?
  reason        String?
  diagnosis     String?
  cost          Float?
  nextVisitAt   DateTime?
  attachmentUrl String?
  notes         String?
  createdAt     DateTime  @default(now())

  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId, date])
  @@index([nextVisitAt])
}

model PetTreatment {
  id        String    @id @default(cuid())
  petId     String
  kind      String    @default("MEDICATION") // MEDICATION|VACCINE|DEWORMER|PARASITE|SUPPLEMENT
  name      String
  dosage    String?
  route     String? // oral|injection|topical|...
  batch     String? // numer serii (szczepionki)
  startDate DateTime  @default(now())
  endDate   DateTime?
  recurring String? // JSON: RecurringRule
  lastDoneAt DateTime?
  nextDueAt DateTime?
  active    Boolean   @default(true)
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  pet  Pet          @relation(fields: [petId], references: [id], onDelete: Cascade)
  logs PetCareLog[]

  @@index([petId])
  @@index([nextDueAt])
}

model PetCareTask {
  id         String    @id @default(cuid())
  petId      String
  category   String    @default("CUSTOM") // FEEDING|CLEANING|GROOMING|WALK|WATER_CHANGE|UVB_REPLACEMENT|WEIGHING|CUSTOM
  title      String
  details    String? // JSON: dane specyficzne (np. typ pokarmu, porcja)
  recurring  String? // JSON: RecurringRule
  lastDoneAt DateTime?
  nextDueAt  DateTime?
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  pet  Pet          @relation(fields: [petId], references: [id], onDelete: Cascade)
  logs PetCareLog[]

  @@index([petId])
  @@index([nextDueAt])
}

model PetCareLog {
  id          String   @id @default(cuid())
  petId       String
  treatmentId String?
  careTaskId  String?
  category    String   @default("CUSTOM") // odzwierciedla kategorię/kind źródła lub FEEDING/HEALTH/...
  occurredAt  DateTime @default(now())
  payload     String? // JSON: np. { outcome: "REFUSED", preyType: "mysz" } lub parametry wody
  note        String?
  createdAt   DateTime @default(now())

  pet       Pet           @relation(fields: [petId], references: [id], onDelete: Cascade)
  treatment PetTreatment? @relation(fields: [treatmentId], references: [id], onDelete: SetNull)
  careTask  PetCareTask?  @relation(fields: [careTaskId], references: [id], onDelete: SetNull)

  @@index([petId, occurredAt])
}

// ─── Pets · Faza 2: Husbandry (terrarium / akwarium) ────────────────────────

model PetEnclosure {
  id           String   @id @default(cuid())
  name         String
  type         String   @default("TERRARIUM") // TERRARIUM|AQUARIUM|PALUDARIUM|CAGE|AVIARY|TANK|OTHER
  lengthCm     Float?
  widthCm      Float?
  heightCm     Float?
  volumeL      Float?
  location     String?
  equipment    String? // JSON: [{ name, kind, installedAt, replaceEveryDays }]
  targetRanges String? // JSON: { paramKey: { min, max } } — nadpisania zakresów
  notes        String?
  ownerId      String?
  ownerTeamId  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner     User?                   @relation("OwnedEnclosures", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerTeam Team?                   @relation("TeamEnclosures", fields: [ownerTeamId], references: [id], onDelete: Cascade)
  pets      Pet[]
  readings  PetEnvironmentReading[]

  @@index([ownerId])
  @@index([ownerTeamId])
}

model PetEnvironmentReading {
  id          String   @id @default(cuid())
  enclosureId String
  measuredAt  DateTime @default(now())
  // Terrarium
  tempWarmC   Float?
  tempCoolC   Float?
  humidityPct Float?
  uvbIndex    Float?
  // Aquarium
  waterTempC  Float?
  ph          Float?
  ammoniaPpm  Float?
  nitritePpm  Float?
  nitratePpm  Float?
  salinityPpt Float?
  gh          Float?
  kh          Float?
  note        String?
  createdAt   DateTime @default(now())

  enclosure PetEnclosure @relation(fields: [enclosureId], references: [id], onDelete: Cascade)

  @@index([enclosureId, measuredAt])
}

// ─── Pets · Faza 3: Hodowla, rodowody, genetyka, sprzedaż ───────────────────

model PetBreedingPair {
  id          String   @id @default(cuid())
  name        String
  species     String   @default("other")
  maleId      String?
  femaleId    String?
  status      String   @default("PLANNED") // PLANNED|PAIRED|COOLING|PRODUCTIVE|RETIRED
  startedAt   DateTime?
  notes       String?
  ownerId     String?
  ownerTeamId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  male      Pet?         @relation("PairMale", fields: [maleId], references: [id], onDelete: SetNull)
  female    Pet?         @relation("PairFemale", fields: [femaleId], references: [id], onDelete: SetNull)
  owner     User?        @relation("OwnedPairs", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerTeam Team?        @relation("TeamPairs", fields: [ownerTeamId], references: [id], onDelete: Cascade)
  clutches  PetClutch[]

  @@index([ownerId])
  @@index([ownerTeamId])
  @@index([maleId])
  @@index([femaleId])
}

model PetClutch {
  id              String    @id @default(cuid())
  pairId          String
  laidAt          DateTime?
  eggCount        Int?
  fertileCount    Int?
  incubationTempC Float?
  humidityPct     Float?
  expectedHatchAt DateTime?
  hatchedAt       DateTime?
  hatchedCount    Int?
  status          String    @default("INCUBATING") // INCUBATING|HATCHED|FAILED
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  pair PetBreedingPair @relation(fields: [pairId], references: [id], onDelete: Cascade)

  @@index([pairId])
  @@index([expectedHatchAt])
}

model PetSale {
  id           String   @id @default(cuid())
  petId        String
  buyerName    String?
  buyerContact String?
  price        Float?
  currency     String   @default("PLN")
  soldAt       DateTime @default(now())
  notes        String?
  ownerId      String?
  ownerTeamId  String?
  createdAt    DateTime @default(now())

  pet       Pet   @relation(fields: [petId], references: [id], onDelete: Cascade)
  owner     User? @relation("OwnedPetSales", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerTeam Team? @relation("TeamPetSales", fields: [ownerTeamId], references: [id], onDelete: Cascade)

  @@index([petId])
  @@index([ownerId])
}

// ─── Flota (pojazdy: serwisy, opony, tankowania) ──────────────────────────

model Vehicle {
  id            String    @id @default(cuid())
  name          String
  make          String? // marka
  model         String?
  year          Int?
  plate         String? // nr rejestracyjny
  vin           String?
  fuelType      String    @default("petrol") // petrol|diesel|lpg|electric|hybrid
  odometer      Int       @default(0) // bieżący przebieg [km]
  inspectionDue DateTime? // przegląd techniczny
  insuranceDue  DateTime? // OC/AC
  notes         String?
  ownerId       String?
  ownerTeamId   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  owner     User?           @relation("OwnedVehicles", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerTeam Team?           @relation("TeamVehicles", fields: [ownerTeamId], references: [id], onDelete: Cascade)
  fuelLogs  FuelLog[]
  services  ServiceRecord[]

  @@index([ownerId])
  @@index([ownerTeamId])
}

model FuelLog {
  id        String   @id @default(cuid())
  vehicleId String
  date      DateTime @default(now())
  odometer  Int // przebieg przy tankowaniu [km]
  liters    Float
  totalCost Float?
  full      Boolean  @default(true) // pełny bak (do wyliczenia zużycia)
  note      String?
  createdAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, date])
}

model ServiceRecord {
  id        String   @id @default(cuid())
  vehicleId String
  date      DateTime @default(now())
  odometer  Int?
  type      String   @default("other") // oil|tires|repair|inspection|insurance|other
  cost      Float?
  note      String?
  createdAt DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, date])
}

// ─── Portfel (elementy majątku + historia zmian salda) ────────────────────

model WalletElement {
  id          String   @id @default(cuid())
  name        String
  kind        String   @default("account") // cash|account|savings|investment|property|receivable|debt
  currency    String   @default("PLN")
  balance     Float    @default(0) // bieżące saldo (zdenormalizowane)
  archived    Boolean  @default(false)
  note        String?
  ownerId     String?
  ownerTeamId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner     User?         @relation("OwnedWalletElements", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerTeam Team?         @relation("TeamWalletElements", fields: [ownerTeamId], references: [id], onDelete: Cascade)
  entries   WalletEntry[]

  @@index([ownerId])
  @@index([ownerTeamId])
}

model WalletEntry {
  id          String   @id @default(cuid())
  elementId   String
  date        DateTime @default(now())
  balanceAfter Float // saldo po zmianie — szereg czasowy do wykresów
  delta       Float // zmiana (+/-)
  kind        String   @default("adjustment") // income|expense|adjustment
  category    String?
  note        String?
  createdAt   DateTime @default(now())

  element WalletElement @relation(fields: [elementId], references: [id], onDelete: Cascade)

  @@index([elementId, date])
}

// ─── LLM model management ───────────────────────────────────────────────────
// Dostawcy LLM (każdy z własnym tokenem) + przypisanie modelu do typu operacji.
// `kind` jako String (konwencja projektu): "openai_compat" | "anthropic".

model LlmProvider {
  id        String   @id @default(cuid())
  label     String // np. "Groq (domyślny)"
  kind      String   @default("openai_compat") // "openai_compat" | "anthropic"
  baseUrl   String // np. https://api.groq.com/openai/v1
  apiKey    String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments LlmAssignment[]
}

// Przypisanie modelu do typu operacji (charakter zadania, nie moduł).
// operationType: "dispatch" | "reasoning" | "vision" | "generation"
model LlmAssignment {
  operationType String   @id
  providerId    String
  model         String
  temperature   Float?
  maxTokens     Int?
  updatedAt     DateTime @updatedAt

  provider LlmProvider @relation(fields: [providerId], references: [id], onDelete: Restrict)

  @@index([providerId])
}

// ─── Nauka języków ──────────────────────────────────────────────────────────

model LanguageDeck {
  id          String   @id @default(cuid())
  name        String
  description String?
  nativeLang  String // język znany, np. "pl"
  targetLang  String // język uczony, np. "en"
  sourceText  String? // tekst, z którego wygenerowano słówka
  ownerId     String?
  ownerTeamId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner     User?        @relation("OwnedLanguageDecks", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerTeam Team?        @relation("TeamLanguageDecks", fields: [ownerTeamId], references: [id], onDelete: SetNull)
  cards     Vocabulary[]

  @@index([ownerId])
  @@index([ownerTeamId])
}

model Vocabulary {
  id           String    @id @default(cuid())
  deckId       String
  term         String // słówko w języku uczonym
  translation  String // tłumaczenie w języku znanym
  example      String?
  partOfSpeech String?
  notes        String?
  // SRS (SuperMemo-2)
  easeFactor     Float     @default(2.5)
  intervalDays   Int       @default(0)
  repetitions    Int       @default(0)
  lapses         Int       @default(0)
  dueAt          DateTime  @default(now())
  lastReviewedAt DateTime?
  createdAt      DateTime  @default(now())

  deck LanguageDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@index([deckId, dueAt])
}

// ─── Zdrowie ──────────────────────────────────────────────────────────────

// Jeden model z dyskryminatorem `kind` (konwencja String, nie enum).
// kind: "VISIT" (wizyta u lekarza) | "TEST" (badanie)
// status: "PLANNED" | "DONE" | "CANCELLED"
model HealthEvent {
  id          String    @id @default(cuid())
  kind        String    @default("VISIT")
  title       String // specjalizacja/cel wizyty lub nazwa badania
  doctorName  String?
  specialty   String?
  facility    String? // placówka / laboratorium
  location    String?
  scheduledAt DateTime
  status      String    @default("PLANNED")
  notes       String?
  result      String? // wynik badania / podsumowanie wizyty
  // Z2: wartość liczbowa wyniku badania + jednostka — do trendów w czasie.
  numericValue Float?
  unit        String?
  referral    String? // skierowanie
  reminderAt  DateTime?
  ownerId     String?
  ownerTeamId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  owner     User? @relation("OwnedHealthEvents", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerTeam Team? @relation("TeamHealthEvents", fields: [ownerTeamId], references: [id], onDelete: SetNull)

  @@index([ownerId, scheduledAt])
  @@index([ownerTeamId, scheduledAt])
}

// ── Leki i pielęgnacja (harmonogram podawania) ───────────────────────────────
// Generyczny harmonogram: leki ORAZ czynności pielęgnacyjne (zmiana opatrunku,
// obcinanie paznokci itd.) — rozróżnia je pole `kind`. Cykliczność trzymamy
// "płasko" (freqType + interval + daysOfWeek + timesOfDay/hourly) — prościej niż
// JSON RecurringRule i wystarcza do: codziennie / wybrane dni / co N dni / co N godzin.
// Wykonania (odhaczenia konkretnych dawek) trafiają do MedicationLog.
model MedicationSchedule {
  id           String    @id @default(cuid())
  kind         String    @default("MEDICATION") // MEDICATION | CARE
  name         String // "Ibuprom" / "Zmiana opatrunku"
  dosage       String? // "200 mg" / "1 tabletka" / "1 plaster"
  route        String? // oral | injection | topical (dla leków)
  reason       String? // wskazanie / po co
  instructions String? // "po posiłku", "lewa ręka"
  freqType     String    @default("DAILY") // DAILY (co N dni) | WEEKLY | HOURLY
  interval     Int       @default(1) // DAILY: co N dni; HOURLY: co N godzin
  daysOfWeek   String? // CSV "1,3,5" (0=nd..6=sb) dla WEEKLY
  timesOfDay   String? // JSON ["08:00","20:00"] dla DAILY/WEEKLY
  hourlyStart  String? // "08:00" — kotwica dla HOURLY
  hourlyEnd    String? // "22:00" — granica dzienna dla HOURLY
  startDate    DateTime  @default(now())
  endDate      DateTime? // okno kuracji (opcjonalne)
  active       Boolean   @default(true)
  notes        String?
  ownerId      String?
  ownerTeamId  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  owner     User?           @relation("OwnedMedicationSchedules", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerTeam Team?           @relation("TeamMedicationSchedules", fields: [ownerTeamId], references: [id], onDelete: SetNull)
  logs      MedicationLog[]

  @@index([ownerId])
  @@index([ownerTeamId])
}

model MedicationLog {
  id         String   @id @default(cuid())
  scheduleId String
  date       String // "YYYY-MM-DD" (lokalny dzień, stabilny klucz)
  slot       String // "HH:MM" — który slot dnia
  outcome    String   @default("TAKEN") // TAKEN | SKIPPED
  takenAt    DateTime @default(now())
  note       String?

  schedule MedicationSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, date, slot])
  @@index([scheduleId, date])
}

// ── Habits (Nawyki) ──────────────────────────────────────────────────────────
// Tracker nawyków: definicja + dziennik wykonań (HabitEntry, jeden wpis na dzień).
// Wzorzec ownerId/ownerTeamId taki sam jak HealthEvent — wsparcie kont i zespołów.
model Habit {
  id          String  @id @default(cuid())
  name        String
  description String?
  icon        String  @default("✅") // emoji
  color       String  @default("var(--accent-orange)") // token CSS motywu
  // CSV dni tygodnia 0=niedz..6=sob, np. "1,2,3,4,5". null/"" = codziennie.
  daysOfWeek  String?
  // HA2: cel tygodniowy (np. 3×/tydzień, dowolne dni). null = tryb dni tygodnia (daysOfWeek).
  weeklyGoal  Int?
  // Godzina przypomnienia w formacie "HH:MM" (czas lokalny). null = bez przypomnienia.
  reminderTime String?
  archived    Boolean @default(false)
  sortOrder   Int     @default(0)
  ownerId     String?
  ownerTeamId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner     User? @relation("OwnedHabits", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerTeam Team? @relation("TeamHabits", fields: [ownerTeamId], references: [id], onDelete: SetNull)
  entries   HabitEntry[]

  @@index([ownerId, archived])
  @@index([ownerTeamId, archived])
}

model HabitEntry {
  id      String @id @default(cuid())
  habitId String
  // Dzień wykonania jako "YYYY-MM-DD" (lokalny) — bez strefy czasowej, stabilne dla heatmapy.
  date    String
  createdAt DateTime @default(now())

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([habitId])
}

// ─── Usługi (Marketplace) ──────────────────────────────────────────────────
// Dwustronny rynek usług (klient ↔ wykonawca) — konkurencja dla Fixly/Booksy.
// Każdy użytkownik może być klientem (składa zlecenia) i/lub wykonawcą
// (zakłada profil + oferty). Status zleceń trzymany jako String + unia TS
// (zasada repo: bez enumów Prisma — kompatybilność z SQLite/Postgres).

// Słownik kategorii usług, trójpoziomowy (system/user/team) wzorem Category.
model ServiceCategory {
  id          String  @id @default(cuid())
  name        String
  icon        String  @default("🛠️") // emoji
  color       String  @default("var(--accent-blue)")
  sortOrder   Int     @default(0)
  // null/null = systemowa (widoczna dla wszystkich); userId = prywatna; teamId = zespołowa.
  userId      String?
  teamId      String?
  createdAt   DateTime @default(now())

  user      User? @relation("OwnedServiceCategories", fields: [userId], references: [id], onDelete: Cascade)
  team      Team? @relation("TeamServiceCategories", fields: [teamId], references: [id], onDelete: Cascade)
  listings  ServiceListing[]

  @@index([userId])
  @@index([teamId])
}

// Profil wykonawcy — jeden na użytkownika (rola „zleceniobiorca").
model ServiceProvider {
  id          String  @id @default(cuid())
  userId      String  @unique
  displayName String
  bio         String?
  // Obszar działania (miasto/region) — wyszukiwanie tekstowe na start.
  area        String?
  phone       String?
  // "1" widoczny w katalogu, "0" ukryty (np. wstrzymany).
  visible     Boolean @default(true)
  // Średnia ocen (denormalizowana dla szybkiego listowania) + liczba ocen.
  ratingAvg   Float   @default(0)
  ratingCount Int     @default(0)
  // M7: weryfikacja wykonawcy (badge zaufania). NIP podaje wykonawca, verified ustawia admin.
  nip         String?
  verified    Boolean @default(false)
  // M5: lokalizacja (filtr „w promieniu X km" + dystans). Ustawiana przez przeglądarkę.
  lat         Float?
  lon         Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User             @relation("UserServiceProvider", fields: [userId], references: [id], onDelete: Cascade)
  listings ServiceListing[]
  requests ServiceRequest[] @relation("ProviderServiceRequests")
  quotes   ServiceQuote[]
  images   ServiceImage[]
  availability ServiceAvailability[]
  favorites    ServiceFavorite[]

  @@index([visible])
}

// M11: ulubieni/obserwowani wykonawcy (per użytkownik). userId jako pole skalarne.
model ServiceFavorite {
  id         String   @id @default(cuid())
  userId     String
  providerId String
  createdAt  DateTime @default(now())

  provider ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([userId, providerId])
  @@index([userId])
}

// Pojedyncza oferta usługi wystawiona przez wykonawcę.
model ServiceListing {
  id          String  @id @default(cuid())
  providerId  String
  categoryId  String?
  title       String
  description String?
  // Model ceny: "fixed" | "hourly" | "quote" (wycena indywidualna).
  priceModel  String  @default("quote")
  // Cena w groszach (gdy fixed/hourly); null dla "quote".
  priceAmount Int?
  currency    String  @default("PLN")
  active      Boolean @default(true)
  // M8/M2: czas trwania usługi (min) + czy klient może rezerwować sloty (Booksy).
  durationMin    Int?
  bookingEnabled Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  provider ServiceProvider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  category ServiceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  requests ServiceRequest[] @relation("ListingServiceRequests")

  @@index([providerId, active])
  @@index([categoryId])
}

// Zlecenie/rezerwacja: klient → wykonawca. Cykl życia w polu status.
model ServiceRequest {
  id          String  @id @default(cuid())
  clientId    String
  providerId  String
  listingId   String?
  title       String
  description String?
  // Preferowany termin realizacji (opcjonalny na etapie zapytania).
  preferredAt DateTime?
  // Ustalony termin po akceptacji przez wykonawcę.
  scheduledAt DateTime?
  // "REQUESTED" | "ACCEPTED" | "DECLINED" | "SCHEDULED" | "IN_PROGRESS" | "COMPLETED" | "CANCELLED"
  status      String  @default("REQUESTED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client   User            @relation("ClientServiceRequests", fields: [clientId], references: [id], onDelete: Cascade)
  provider ServiceProvider @relation("ProviderServiceRequests", fields: [providerId], references: [id], onDelete: Cascade)
  listing  ServiceListing? @relation("ListingServiceRequests", fields: [listingId], references: [id], onDelete: SetNull)
  review   ServiceReview?
  messages ServiceMessage[]
  quotes   ServiceQuote[]
  payment  ServicePayment?

  @@index([clientId, status])
  @@index([providerId, status])
}

// Płatność za zlecenie (M9): kwota, metoda, status. Spięcie z Portfelem opt-in
// (osobno strona wykonawcy=przychód i klienta=wydatek). Jedna płatność / zlecenie.
model ServicePayment {
  id        String    @id @default(cuid())
  requestId String    @unique
  amount    Int // grosze
  currency  String    @default("PLN")
  method    String    @default("cash") // cash|transfer|card|other
  status    String    @default("UNPAID") // UNPAID|PAID
  invoiceNo String?
  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  request ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
}

// Ocena wystawiana przez klienta po zakończeniu zlecenia (1 na zlecenie).
model ServiceReview {
  id        String  @id @default(cuid())
  requestId String  @unique
  authorId  String
  rating    Int     // 1–5
  comment   String?
  createdAt DateTime @default(now())

  request ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  author  User           @relation("AuthoredServiceReviews", fields: [authorId], references: [id], onDelete: Cascade)
}

// ─── Wiadomości (News) ────────────────────────────────────────────────────
// Personalizowane streszczenia wiadomości z monitorowaniem tematów. Pobieranie
// na żądanie (RSS + dociągnięcie artykułu), twardy limit świeżości 24h, baza
// wiedzy per (temat × źródło) z wersjonowaniem. Prywatne per użytkownik.

model NewsSource {
  id          String   @id @default(cuid())
  ownerId     String
  // Stabilny klucz źródła: "onet" | "okopress" | "niezalezna" | własny slug.
  key         String
  name        String
  rssUrl      String
  homepageUrl String
  // Profil światopoglądowy do oznaczania widoku: "left" | "center" | "right".
  leaning     String   @default("center")
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  owner     User            @relation("OwnedNewsSources", fields: [ownerId], references: [id], onDelete: Cascade)
  items     NewsItem[]
  knowledge NewsKnowledge[]

  @@unique([ownerId, key])
  @@index([ownerId])
}

model NewsTopic {
  id              String    @id @default(cuid())
  ownerId         String
  title           String
  // Filtr semantyczny w naturalnym języku (np. „perypetie Z. Ziobry w sprawie zarzutów").
  semanticFilter  String
  enabled         Boolean   @default(true)
  sortOrder       Int       @default(0)
  lastRefreshedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  owner     User            @relation("OwnedNewsTopics", fields: [ownerId], references: [id], onDelete: Cascade)
  items     NewsItem[]
  knowledge NewsKnowledge[]

  @@index([ownerId])
}

// Wersjonowany stan wiedzy dla (temat × źródło). Bieżący stan = najwyższy version.
model NewsKnowledge {
  id        String   @id @default(cuid())
  topicId   String
  sourceId  String
  version   Int
  // Markdown — narastający opis stanu wiedzy na temat (z perspektywy źródła).
  content   String
  // Jednozdaniowy nagłówek „aktualny stan" do podglądu.
  headline  String?
  // Markdown — opis CO SIĘ ZMIENIŁO w tej wersji względem poprzedniej
  // (dla wersji bazowej: jak zbudowano bazę + jaka była ostatnia znana informacja).
  changeNote String?
  // Znacznik świeżości: najnowsza DATA PUBLIKACJI materiału wchłoniętego w tej
  // wersji. Kolejne odświeżenia pobierają tylko wiadomości nowsze niż ten znacznik.
  lastPublishedAt DateTime?
  createdAt DateTime @default(now())

  topic  NewsTopic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  source NewsSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([topicId, sourceId, version])
  @@index([topicId, sourceId])
}

model NewsItem {
  id            String   @id @default(cuid())
  topicId       String
  sourceId      String
  url           String
  title         String
  // Bieżące streszczenie w wybranej długości.
  summary       String
  // "short" | "medium" | "long" — poziom szczegółowości streszczenia.
  summaryLength String   @default("medium")
  // Co nowego wnosi względem stanu wiedzy (uzasadnienie „nowości").
  noveltyNote   String?
  imageUrl      String?
  publishedAt   DateTime
  // "PENDING" | "ACKNOWLEDGED" | "DISMISSED". Tylko ACKNOWLEDGED trafia do bazy wiedzy.
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())

  topic  NewsTopic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  source NewsSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@unique([topicId, sourceId, url])
  @@index([topicId, status])
}

model NewsPref {
  ownerId              String   @id
  // Domyślna długość streszczeń: "short" | "medium" | "long".
  defaultSummaryLength String   @default("medium")
  // Ostatnio wybrane źródło w widoku (klucz NewsSource).
  activeSourceKey      String?
  updatedAt            DateTime @updatedAt

  owner User @relation("NewsPref", fields: [ownerId], references: [id], onDelete: Cascade)
}

// ─── Pogoda (Weather) ─────────────────────────────────────────────────────
// Dane pogodowe pobierane na żywo z Open-Meteo (bez klucza). W bazie trzymamy
// tylko lokalizacje i „obserwatory" (alerty) użytkownika. Prywatne per user.

model WeatherLocation {
  id        String   @id @default(cuid())
  ownerId   String
  label     String
  lat       Float
  lon       Float
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  owner User @relation("OwnedWeatherLocations", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

model WeatherWatcher {
  id        String   @id @default(cuid())
  ownerId   String
  title     String
  // "preset" (gotowy scenariusz aktywności) | "custom" (opis w naturalnym języku).
  kind      String   @default("preset")
  presetKey String?
  // Treść obserwatora dla kind=custom (np. „weekend dobry na rower w górach").
  query     String?
  // Horyzont czasowy: "today" | "tomorrow" | "weekend" | "week".
  horizon   String   @default("week")
  enabled   Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  owner User @relation("OwnedWeatherWatchers", fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

// ─── Warsztaty (Workshop) ───────────────────────────────────────────────────
// Zarządzanie przydomowym warsztatem/pracownią DOWOLNEGO typu (stolarski,
// samochodowy, malarski, elektroniczny…). Tryb Dom (hobbysta) / Pro (firma,
// kolektyw, zespół) — per-user, jak StorageSettings.

model WarsztatSettings {
  userId    String   @id
  mode      String   @default("home") // "home" | "pro"
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Pojedynczy warsztat/pracownia. `type` = klucz profilu z katalogu podpowiedzi
// (src/lib/warsztat/catalog.ts), np. "stolarski" | "samochodowy" | "malarski".
model Workshop {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("ogolny")
  description String?
  location    String?
  ownerId     String?
  ownerTeamId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner     User?             @relation("OwnedWorkshops", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerTeam Team?             @relation("TeamWorkshops", fields: [ownerTeamId], references: [id], onDelete: Cascade)
  items     WorkshopItem[]
  projects  WorkshopProject[]

  @@index([ownerId])
  @@index([ownerTeamId])
}

// Wyposażenie warsztatu: narzędzia, maszyny, materiały eksploatacyjne, BHP.
// Dostęp dziedziczony z Workshop (brak własnego ownera). `kind`/`condition`/
// `status` to String (SQLite = brak enumów).
model WorkshopItem {
  id            String    @id @default(cuid())
  workshopId    String
  name          String
  kind          String    @default("tool") // "tool" | "machine" | "consumable" | "safety" | "material"
  category      String?
  quantity      Float?
  unit          String?
  minQuantity   Float?    // próg low-stock (głównie materiały eksploatacyjne)
  condition     String    @default("good") // "new" | "good" | "worn" | "broken"
  status        String    @default("owned") // "owned" | "wishlist"
  brand         String?
  station       String?   // stanowisko / miejsce w warsztacie
  assignedTo    String?   // Pro: kto aktualnie ma narzędzie / komu wypożyczone
  purchasePrice Float?
  purchaseDate  DateTime?
  lastServiceAt DateTime?
  nextServiceAt DateTime? // termin następnego przeglądu/serwisu
  suggestionKey String?   // powiązanie z pozycją katalogu podpowiedzi
  photoUrl      String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([workshopId])
  @@index([nextServiceAt])
}

// Pro: prosty dziennik projektów/zleceń realizowanych w warsztacie.
model WorkshopProject {
  id          String    @id @default(cuid())
  workshopId  String
  name        String
  description String?
  status      String    @default("planned") // "planned" | "active" | "done"
  assignedTo  String?
  startedAt   DateTime?
  dueAt       DateTime?
  doneAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workshop Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([workshopId])
}

// ─── Powiadomienia (NM3) ──────────────────────────────────────────────────
// Centralny silnik powiadomień zaprojektowany pod free tier (bez crona): skan
// nadchodzących terminów uruchamiany przy logowaniu / na żądanie (otwarcie
// dzwonka) generuje rekordy idempotentnie (dedupeKey). Web-push to przyszłe
// rozszerzenie — model jest fundamentem zarówno dla in-app, jak i push.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  module    String // tasks|health|flota|pets|languages|kitchen|services|system…
  title     String
  body      String?
  href      String?
  // Kiedy zdarzenie źródłowe jest należne (sortowanie + przyszłe push).
  dueAt     DateTime?
  readAt    DateTime?
  // Deterministyczny klucz źródła (np. "task-due-<id>"), by skan nie duplikował.
  dedupeKey String?
  createdAt DateTime  @default(now())

  user User @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// ─── Marketplace: czat (M1) i wyceny (M3) ─────────────────────────────────
// Wątek wiadomości i historia wycen są zakotwiczone w zleceniu (ServiceRequest)
// — to wspólny kontener obu torów (Fixly/Booksy). Statusy jako String + unia TS.
model ServiceMessage {
  id        String    @id @default(cuid())
  requestId String
  senderId  String
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  request ServiceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sender  User           @relation("SentServiceMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([requestId, createdAt])
}

model ServiceQuote {
  id         String    @id @default(cuid())
  requestId  String
  providerId String
  amount     Int // grosze
  currency   String    @default("PLN")
  message    String?
  status     String    @default("SENT") // SENT | ACCEPTED | REJECTED
  validUntil DateTime?
  createdAt  DateTime  @default(now())

  request  ServiceRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  provider ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([requestId, createdAt])
}

// Dostępność wykonawcy (M2): reguły tygodniowe. weekday 0=niedz…6=sob; minuty od północy.
model ServiceAvailability {
  id         String @id @default(cuid())
  providerId String
  weekday    Int // 0..6
  startMin   Int // np. 540 = 09:00
  endMin     Int // np. 1020 = 17:00

  provider ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, weekday])
}

// Portfolio wykonawcy (M4): zdjęcia realizacji. url = data-URL lub link (wzorzec RecipeImage).
model ServiceImage {
  id         String   @id @default(cuid())
  providerId String
  url        String
  caption    String?
  order      Int      @default(0)
  createdAt  DateTime @default(now())

  provider ServiceProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, order])
}

// ─── Kontakty / osobisty CRM (NM9) ─────────────────────────────────────────
// Lekki CRM: baza relacji (klienci/wykonawcy/znajomi). Własność 3-poziom
// (ownerId/ownerTeamId jako pola skalarne — dostęp przez ownedByWhere). tags = JSON string[].
model Contact {
  id          String   @id @default(cuid())
  name        String
  phone       String?
  email       String?
  company     String?
  tags        String? // JSON: string[]
  notes       String?
  ownerId     String?
  ownerTeamId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId])
  @@index([ownerTeamId])
}
