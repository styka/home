datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── NextAuth required models ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  avatarUrl     String?
  role          String    @default("USER")  // "USER" | "ADMIN"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  ownedTeams          Team[]           @relation("TeamOwner")
  teamMemberships     TeamMember[]
  sentInvitations     TeamInvitation[] @relation("InvitedBy")
  receivedInvitations TeamInvitation[] @relation("InvitedUser")
  ownedLists          ShoppingList[]
  ownedActions        Action[]         @relation("UserOwnedActions")
  grantsCreated       Share[]          @relation("ShareGrantor")
  sharesReceived      Share[]          @relation("ShareRecipientUser")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Teams ────────────────────────────────────────────────────────────────

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  avatarUrl   String?
  ownerId     String
  parentTeamId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner          User             @relation("TeamOwner", fields: [ownerId], references: [id])
  parentTeam     Team?            @relation("SubTeams", fields: [parentTeamId], references: [id])
  subTeams       Team[]           @relation("SubTeams")
  members        TeamMember[]
  invitations    TeamInvitation[]
  lists          ShoppingList[]   @relation("TeamLists")
  ownedActions   Action[]         @relation("TeamOwnedActions")
  sharesReceived Share[]          @relation("ShareRecipientTeam")
}

model TeamMember {
  teamId    String
  userId    String
  role      String   @default("MEMBER")  // "MEMBER" | "ADMIN" | "OWNER"
  joinedAt  DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
}

model TeamInvitation {
  id            String   @id @default(cuid())
  teamId        String
  invitedById   String
  invitedUserId String
  status        String   @default("PENDING")  // "PENDING" | "ACCEPTED" | "REJECTED"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  team        Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedBy   User @relation("InvitedBy", fields: [invitedById], references: [id])
  invitedUser User @relation("InvitedUser", fields: [invitedUserId], references: [id])

  @@unique([teamId, invitedUserId])
}

// ─── Shopping ─────────────────────────────────────────────────────────────

model ShoppingList {
  id          String   @id @default(cuid())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ownerId     String?
  ownerTeamId String?

  owner     User?  @relation(fields: [ownerId], references: [id])
  ownerTeam Team?  @relation("TeamLists", fields: [ownerTeamId], references: [id])
  items     Item[]
}

model Item {
  id        String   @id @default(cuid())
  name      String
  quantity  Float?
  unit      String?
  category  String   @default("Other")
  status    String   @default("NEEDED")
  notes     String?
  priority  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  listId    String

  list ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)
}

model ItemHistory {
  id        String   @id @default(cuid())
  name      String   @unique
  category  String
  unit      String?
  useCount  Int      @default(1)
  updatedAt DateTime @updatedAt
}

// ─── Sharing ──────────────────────────────────────────────────────────────

model Share {
  id              String   @id @default(cuid())
  resourceType    String   // "ShoppingList" | "Action"
  resourceId      String
  permission      String   @default("VIEW")  // "VIEW" | "EDIT" | "MANAGE"
  grantedById     String
  recipientUserId String?
  recipientTeamId String?
  createdAt       DateTime @default(now())

  grantedBy     User  @relation("ShareGrantor",       fields: [grantedById],     references: [id])
  recipientUser User? @relation("ShareRecipientUser", fields: [recipientUserId], references: [id])
  recipientTeam Team? @relation("ShareRecipientTeam", fields: [recipientTeamId], references: [id])

  @@index([resourceType, resourceId])
  @@index([recipientUserId])
  @@index([recipientTeamId])
}

// ─── Quick Actions ────────────────────────────────────────────────────────

model ActionComponent {
  id            String  @id @default(cuid())
  name          String  @unique
  type          String  // "LINK_BUTTON" | "WEATHER_GENERATOR"
  description   String?
  isBuiltIn     Boolean @default(false)
  defaultParams String? // JSON: {"url":"https://onet.pl","label":"Onet"}

  actions Action[]
}

model Action {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("ACTIVE")  // "ACTIVE" | "IN_PROGRESS" | "DONE" | "ARCHIVED"
  dueDate     DateTime?
  completedAt DateTime?

  componentId String
  params      String?   // JSON: component-specific parameters

  isRecurring      Boolean   @default(false)
  recurPattern     String?   // "DAILY" | "WEEKLY" | "MONTHLY" | "YEARLY"
  recurInterval    Int?
  recurDaysOfWeek  String?   // JSON array "[1,3,5]"
  recurDayOfMonth  Int?
  recurMonthOfYear Int?
  nextDueDateBasis String?   // "PLANNED" | "COMPLETION"
  nextDueDate      DateTime?
  lastAdvancedAt   DateTime?

  ownerUserId String?
  ownerTeamId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  component ActionComponent @relation(fields: [componentId], references: [id])
  ownerUser User?  @relation("UserOwnedActions", fields: [ownerUserId], references: [id])
  ownerTeam Team?  @relation("TeamOwnedActions", fields: [ownerTeamId], references: [id])

  @@index([ownerUserId])
  @@index([ownerTeamId])
  @@index([status])
  @@index([dueDate])
}
